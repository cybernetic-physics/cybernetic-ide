name: cybernetic-ide
title: Cybernetic IDE
base: core24
version: "$RELEASE_VERSION"
summary: Robotics IDE with an embedded Unitree G1 MuJoCo viewer
description: |
  Cybernetic IDE is a robotics development environment built on a Zed editor
  foundation with an embedded Unitree G1 MuJoCo viewer, Dockerized simulator
  runtime, and Unitree SDK-shaped control path.
grade: stable
confinement: classic
compression: lzo
website: https://cyberneticphysics.com/
source-code: https://github.com/cybernetic-physics/cybernetic-ide
issues: https://github.com/cybernetic-physics/cybernetic-ide/issues
contact: https://github.com/cybernetic-physics/cybernetic-ide/issues

parts:
  zed:
    plugin: dump
    source: "https://github.com/zed-industries/zed/releases/download/v$RELEASE_VERSION/zed-linux-x86_64.tar.gz"

    organize:
      # These renames seem to not be necessary, but it's tidier.
      bin: usr/bin
      libexec: usr/libexec

    stage-packages:
      - libasound2t64
      # snapcraft has a lint that this is unused, but without it Zed exits with
      # "Missing Vulkan entry points: LibraryLoadFailure" in wgpu.
      - libvulkan1
      # snapcraft has a lint that this is unused, but without it Zed exits with
      # "NoWaylandLib" when run with Wayland.
      - libwayland-client0
      - libxcb1
      - libxkbcommon-x11-0
      - libxkbcommon0

    build-attributes:
      - enable-patchelf

    prime:
      # Omit unneeded files from the tarball
      - -lib
      - -licenses.md
      - -share

      # Omit unneeded files from stage-packages
      - -etc
      - -usr/share/doc
      - -usr/share/lintian
      - -usr/share/man

apps:
  zed:
    command: usr/bin/zed
    common-id: org.cyberneticphysics.CyberneticIDE
    environment:
      ZED_BUNDLE_TYPE: snap
