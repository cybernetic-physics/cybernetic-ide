<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
    <id>$APP_ID</id>
    <metadata_license>MIT</metadata_license>
    <project_license>Apache-2.0 and GPL-3.0-or-later</project_license>

    <name>$APP_NAME</name>
    <summary>Robotics IDE with an embedded Unitree G1 MuJoCo viewer</summary>
    <developer id="org.cyberneticphysics">
        <name translate="no">Cybernetic Physics</name>
    </developer>
    <description>
        <p>
            Cybernetic IDE blends a high-performance code editor with robotics simulation workflows, starting with an embedded Unitree G1 MuJoCo viewer and a Dockerized simulator runtime.
        </p>
        <p>Features:</p>
        <ul>
            <li>Performance: Efficiently uses every CPU core and your GPU for instant startup, quick file loading, and responsive keystrokes.</li>
            <li>Language-aware: Maintains a syntax tree for precise highlighting, and auto-indent, with LSP support for autocompletion and refactoring.</li>
            <li>Collaboration: Real-time editing and navigation for multiple developers in a shared workspace.</li>
            <li>Robotics: Opens a Robot Viewer beside code and talks to a local Unitree G1 MuJoCo harness.</li>
            <li>SDK workflow: Provides a Unitree SDK-shaped Python facade for simulator-backed G1 control demos.</li>
            <li>AI Integration: Preserves inherited assistant and editor automation features from the upstream editor foundation.</li>
        </ul>
    </description>

    <launchable type="desktop-id">$APP_ID.desktop</launchable>

    <branding>
        <color type="primary" scheme_preference="light">$BRANDING_LIGHT</color>
        <color type="primary" scheme_preference="dark">$BRANDING_DARK</color>
    </branding>

    <content_rating type="oars-1.1">
        <content_attribute id="social-chat">intense</content_attribute>
        <content_attribute id="social-audio">intense</content_attribute>
    </content_rating>

    <url type="homepage">https://cyberneticphysics.com</url>
    <url type="bugtracker">https://github.com/cybernetic-physics/cybernetic-ide/issues</url>
    <url type="faq">https://github.com/cybernetic-physics/cybernetic-ide#readme</url>
    <url type="help">https://github.com/cybernetic-physics/cybernetic-ide/tree/main/docs</url>
    <url type="contact">https://github.com/cybernetic-physics/cybernetic-ide/issues</url>
    <url type="vcs-browser">https://github.com/cybernetic-physics/cybernetic-ide</url>
    <url type="contribute">https://github.com/cybernetic-physics/cybernetic-ide</url>

    <supports>
        <internet>offline-only</internet>
    </supports>
    <recommends>
        <control>pointing</control>
        <control>keyboard</control>
        <display_length compare="ge">768</display_length>
    </recommends>

    <screenshots>
        <screenshot type="default">
            <caption>Cybernetic IDE with a Unitree G1 MuJoCo viewer beside Python control code</caption>
            <image>https://zed.dev/img/flatpak/flatpak-1.png</image>
        </screenshot>
        <screenshot>
            <caption>Cybernetic IDE with code and collaboration panels</caption>
            <image>https://zed.dev/img/flatpak/flatpak-2.png</image>
        </screenshot>
        <screenshot>
            <caption>Example of a channel's shared document</caption>
            <image>https://zed.dev/img/flatpak/flatpak-3.png</image>
        </screenshot>
        <screenshot>
            <caption>Cybernetic IDE extension list</caption>
            <image>https://zed.dev/img/flatpak/flatpak-4.png</image>
        </screenshot>
        <screenshot>
            <caption>Theme switcher UI and example theme</caption>
            <image>https://zed.dev/img/flatpak/flatpak-5.png</image>
        </screenshot>
    </screenshots>

    <releases>
		@release_info@
		<release version="0.0.0" date="1970-01-01">
			<description>
				<p>Dummy release to keep flatpak-builder AppStream metadata validation from complaining</p>
			</description>
		</release>
    </releases>
</component>
